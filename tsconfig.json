{
  "extends": "astro/tsconfigs/strict",
    "include": [
        ".astro/types.d.ts",
        "**/*"
    ],
    "exclude": [
        "dist"
    ],
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "@components/*": [
                "src/components/*"
            ],
            "@layouts/*": [
                "src/layouts/*"
            ],
            "@config/*": [
                "src/config/*"
            ],
            "@consts/*": [
                "src/consts/*"
            ],
            "@interfaces/*": [
                "src/interfaces/*"
            ],
            "@scripts/*": [
                "src/scripts/*"
            ],
            "@assets/*": [
                "src/assets/*"
            ],
            "@src/*": [
                "src/*"
            ]
        },
        "ignoreDeprecations": "6.0",
        "types": ["astro/client", "node", "jquery", "jqueryui"]
    }
}
