import '@styles/buttons/buttons.css';


---


<!--  -----  LAYOUT BTN-NAVBAR THEMES JQUERY UI  -----  -->
<div class="layout__btn-navbars-themes-jquery-ui" id="btnNavbarThemesJQueryUI">

    <!--  -----  Contenedor del Botón Navbar de Themes jQuery UI de Navegación  -----  -->
    <div class="btn-navbar-themes-jquery-ui__container">

        <!--  -----  Botón del Menú Hamburguesa de Navegación Open -----  -->
